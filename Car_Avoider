#include <LedControl.h>

LedControl lc = LedControl(11, 13, 10, 1); // DIN, CLK, CS, عدد المصفوفات

const int joyX = A0;
const int buzzer = 3;

int playerX = 3;
unsigned long lastMoveTime = 0;
int moveInterval = 500; // الزمن بين كل حركة للأعداء
int score = 0;

bool cars[8][8]; // تمثل العربيات

void setup() {
  lc.shutdown(0, false);
  lc.setIntensity(0, 8);
  lc.clearDisplay(0);
  pinMode(buzzer, OUTPUT);

  resetGame();
}

void loop() {
  lc.clearDisplay(0);

  // تحريك اللاعب بالجويستيك
  int xVal = analogRead(joyX);
  if (xVal < 400 && playerX > 0) playerX--;
  else if (xVal > 600 && playerX < 7) playerX++;

  // تحديث العربيات كل فترة
  if (millis() - lastMoveTime > moveInterval) {
    moveCarsDown();
    spawnCar();
    lastMoveTime = millis();
    score++;

    // زيادة السرعة تدريجيا
    if (score % 10 == 0 && moveInterval > 150)
      moveInterval -= 20;
  }

  // عرض العربيات
  for (int y = 0; y < 8; y++)
    for (int x = 0; x < 8; x++)
      if (cars[y][x]) lc.setLed(0, y, x, true);

  // عرض السيارة
  lc.setLed(0, 7, playerX, true);

  // تحقق من التصادم
  if (cars[7][playerX]) {
    gameOver();
    resetGame();
    return;
  }

  delay(100);
}

void moveCarsDown() {
  for (int y = 7; y > 0; y--)
    for (int x = 0; x < 8; x++)
      cars[y][x] = cars[y - 1][x];

  // مسح الصف العلوي
  for (int x = 0; x < 8; x++)
    cars[0][x] = false;
}

void spawnCar() {
  // نسبة ظهور عربية جديدة 40%
  int chance = random(100);
  if (chance < 40) {
    int carPos = random(8);
    cars[0][carPos] = true;
  }
}

void resetGame() {
  playerX = 3;
  moveInterval = 500;
  score = 0;

  for (int y = 0; y < 8; y++)
    for (int x = 0; x < 8; x++)
      cars[y][x] = false;

  lc.clearDisplay(0);
}

void gameOver() {
  for (int i = 0; i < 3; i++) {
    tone(buzzer, 200 + i * 200, 200);
    lc.clearDisplay(0);
    delay(200);
    for (int y = 0; y < 8; y++)
      for (int x = 0; x < 8; x++)
        lc.setLed(0, y, x, true);
    delay(200);
  }
  noTone(buzzer);
  lc.clearDisplay(0);
  delay(1000);
}
