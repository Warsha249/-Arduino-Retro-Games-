float mapf(float x, float in_min, float in_max, float out_min, float out_max) {
  return (x - in_min) * (out_max - out_min) / (in_max - in_min) + out_min;
}

void beep(int note, int duration) {
  tone(Pin::buzzerPin, note, duration);
  delay(duration);
  noTone(Pin::buzzerPin);
  delay(10);
}

void startSound() {
  beep(c, 200); beep(d, 200); beep(f, 200); beep(gS, 800);
}

void gamoverSound() {
  beep(f, 200); beep(f, 200); beep(c, 800);
}

void initialize() {
  matrix.shutdown(0, false);
  matrix.setIntensity(0, intensity);
  matrix.clearDisplay(0);
  randomSeed(analogRead(A5));
  snake.row = random(8);
  snake.col = random(8);
}

void calibrateJoystick() {
  long x = 0, y = 0;
  for (int i = 0; i < 10; i++) {
    x += analogRead(Pin::joystickX);
    y += analogRead(Pin::joystickY);
  }
  joystickHome.x = x / 10;
  joystickHome.y = y / 10;
}

float lnx(float n) {
  if(n < 0) return 0;
  if(n > 1) return 1;
  n = -log(-n * logarithmity + 1); 
  if (isinf(n)) n = lnx(0.999999); 
  return n;
}

void showSnakeMessage() {
  for (int d = 0; d < (int)sizeof(snejkMessage[0]) - 7; d++) {
    for (int col = 0; col < 8; col++) {
      delay(messageSpeed);
      for (int row = 0; row < 8; row++) {
        matrix.setLed(0, row, col, pgm_read_byte(&(snejkMessage[row][col + d])));
      }
    }
  }
}

void showGameOverMessage() {
  for (int d = 0; d < (int)sizeof(gameOverMessage[0]) - 7; d++) {
    for (int col = 0; col < 8; col++) {
      delay(messageSpeed);
      for (int row = 0; row < 8; row++) {
        matrix.setLed(0, row, col, pgm_read_byte(&(gameOverMessage[row][col + d])));
      }
    }
  }
}

void showScoreMessage(int score) {
  if (score < 0 || score > 99) return;
  int second = score % 10;
  int first = (score / 10) % 10;
  for (int d = 0; d < (int)sizeof(scoreMessage[0]) + 16; d++) {
    for (int col = 0; col < 8; col++) {
      delay(messageSpeed);
      for (int row = 0; row < 8; row++) {
        if (d <= (int)sizeof(scoreMessage[0]) - 8) {
          matrix.setLed(0, row, col, pgm_read_byte(&(scoreMessage[row][col + d])));
        }
        int c = col + d - (int)sizeof(scoreMessage[0]) + 6;
        if (score < 10) c += 8;
        if (c >= 0 && c < 8) {
          if (first > 0) matrix.setLed(0, row, col, pgm_read_byte(&(digits[first][row][c])));
        } else {
          c -= 8;
          if (c >= 0 && c < 8) matrix.setLed(0, row, col, pgm_read_byte(&(digits[second][row][c])));
        }
      }
    }
  }
}

void scanJoystick() {
  int previousDirection = snakeDirection; 
  long timestamp = millis() + snakeSpeed; 
  while (millis() < timestamp) {
    float raw = mapf(analogRead(Pin::potentiometer), 0, 1023, 0, 1);
    snakeSpeed = mapf(lnx(raw), lnx(0), lnx(1), 10, 1000);
    if (snakeSpeed == 0) snakeSpeed = 1; 

    int xVal = analogRead(Pin::joystickX);
    int yVal = analogRead(Pin::joystickY);

    if (xVal < joystickHome.x - joystickThreshold) snakeDirection = left;
    else if (xVal > joystickHome.x + joystickThreshold) snakeDirection = right;
    else if (yVal < joystickHome.y - joystickThreshold) snakeDirection = up;
    else if (yVal > joystickHome.y + joystickThreshold) snakeDirection = down;

    if ((snakeDirection + 2 == previousDirection || snakeDirection - 2 == previousDirection) && previousDirection != 0) {
      snakeDirection = previousDirection;
    }
    matrix.setLed(0, food.row, food.col, 1);
  }
}

void fixEdge() {
  if (snake.col < 0) snake.col = 7;
  else if (snake.col > 7) snake.col = 0;
  if (snake.row < 0) snake.row = 7;
  else if (snake.row > 7) snake.row = 0;
}

void updateAges() {
  for (int row = 0; row < 8; row++) {
    for (int col = 0; col < 8; col++) {
      if (age[row][col] > 0 ) age[row][col]++;
      if (age[row][col] > snakeLength) {
        matrix.setLed(0, row, col, 0);
        age[row][col] = 0;
      }
    }
  }
}

void generateFood() {
  if (food.row == -1 || food.col == -1) {
    if (snakeLength >= 64) { win = true; return; }
    do {
      food.col = random(8);
      food.row = random(8);
    } while (age[food.row][food.col] > 0);
  }
}

void calculateSnake() {
  switch (snakeDirection) {
    case up:    snake.row--; break;
    case right: snake.col++; break;
    case down:  snake.row++; break;
    case left:  snake.col--; break;
    default: return;
  }
  fixEdge();
  if (age[snake.row][snake.col] != 0 && snakeDirection != 0) {
    gamoverSound();
    gameOver = true;
    return;
  }
  if (snake.row == food.row && snake.col == food.col) {
    beep(fH, 30);
    snakeLength++;
    food.row = -1; food.col = -1;
  }
  updateAges();
  age[snake.row][snake.col]++;
  matrix.setLed(0, snake.row, snake.col, 1);
}

void unrollSnake() {
  matrix.setLed(0, food.row, food.col, 0);
  delay(600);
  for (int i = 1; i <= snakeLength; i++) {
    for (int row = 0; row < 8; row++) {
      for (int col = 0; col < 8; col++) {
        if (age[row][col] == i) {
          matrix.setLed(0, row, col, 0);
          delay(100);
        }
      }
    }
  }
}

void handleGameStates() {
  if (gameOver || win) {
    unrollSnake();
    showScoreMessage(snakeLength);
    if (gameOver) showGameOverMessage();
    win = false; gameOver = false;
    snakeLength = initialSnakeLength;
    snakeDirection = 0;
    memset(age, 0, sizeof(age));
    matrix.clearDisplay(0);
    startSound();
  }
}

void setup() {
  Serial.begin(115200); 
  initialize();         
  calibrateJoystick(); 
  showSnakeMessage(); 
  startSound();      
}

void loop() {
  generateFood();    
  scanJoystick();    
  calculateSnake();  
  handleGameStates();
}
